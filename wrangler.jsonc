{
  // Cloudflare Workers 設定。デプロイ手順は docs/deploy-cloudflare.md を参照
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shift-craft",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  // @anthropic-ai/sdk が Node 組み込み(path 等)を使うため必須
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // /api/* は静的アセットより先に必ず Worker を通す
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "shift-craft-db",
      "database_id": "00a1fa9b-482b-4b0a-a02e-b996e54bbb4a",
      "migrations_dir": "migrations"
    }
  ]
  // 新規登録は承認不要になったため、承認メール用の Email Routing 送信バインディング
  // (send_email) は不要。パスワード再設定メールは Resend（RESEND_API_KEY シークレット）
  // 経由で利用者へ直接送る（docs/deploy-cloudflare.md 参照）。
}
